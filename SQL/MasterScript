--STEP 1: VERIFYING ROW COUNT
--GOAL: ENSURE ALL 1,048,575 R0WS ARE IMPORTED
SELECT COUNT (*) AS TOTAL_ROWS FROM flight_data;


--STEP 2: NEW YORK HUB PERFORMANCE
--GOAL: COMPARE JFK, LGA, AND EWR (NEWARK)
SELECT 
ORIGIN,
COUNT(*) AS TOTAL_FLIGHTS,
--USING WEATHER DELAY AS THERE IS NO DEPARTURE DELAY COLUMN IN THE IMPORTED DATA SET
ROUND(AVG(WEATHER_DELAY), 2) AS AVG_WEATHER_DELAY,
ROUND(AVG(LATE_AIRCRAFT_DELAY), 2) AS AVG_TECH_DELAY,
SUM (CANCELLED) AS TOTAL_CANCELLED
FROM flight_data
WHERE ORIGIN IN ('JFK', 'LGA', 'EWR')
GROUP BY ORIGIN 
ORDER BY AVG_TECH_DELAY;




--STEP 3: TIME=OF-DAY AUDIT
--GOAL: IDENTIFY THE "DANGER ZONE" HOURS FOR NEW YORK HUBS
SELECT 
ORIGIN,
CAST (DEP_TIME/100 AS INT) AS HOUR_OF_DAY,
--THIS TRUNCATES TIME TO ITS FIRST DIGITS MAKING IT A WHOLE NUMBER
COUNT (*) AS FLIGHT_COUNT,
ROUND(AVG(LATE_AIRCRAFT_DELAY), 2) AS AVG_TECH_DELAY,
SUM (CANCELLED) AS TOTAL_CANCELS,
--TOTAL IMPACT (WEATHER + TECH)
ROUND(AVG(WEATHER_DELAY + LATE_AIRCRAFT_DELAY), 2) AS TOTAL_AVG_DELAY
FROM FLIGHT_DATA
WHERE ORIGIN IN ('JFK', 'LGA', 'EWR')
AND DEP_TIME IS NOT NULL -- SKIP FLIGHTS THAT NEVER LEFT
GROUP BY ORIGIN, HOUR_OF_DAY
ORDER BY AVG_TECH_DELAY DESC
LIMIT 15;

--STEP 4: TECH DELAY BENCHMARKING
--GOAL: SEE IF LGA/EWR ARE "TECH OUTLIERS" COMPARED TO THE NATIONAL AVERAGE
SELECT 
'NYC_HUBS' AS GROUP_NAME,
ROUND(AVG(LATE_AIRCRAFT_DELAY), 2) AS AVG_TECH_DELAY,
ROUND(CAST(SUM(CANCELLED) AS FLOAT) / COUNT(*) * 100, 2) AS CANCEL_RATE
FROM flight_data
WHERE ORIGIN IN ('JFK', 'LGA', 'EWR')
UNION ALL 
SELECT 
'REST_OF_USA' AS GROUP_NAME,
ROUND(AVG(LATE_AIRCRAFT_DELAY), 2) AS AVG_TECH_DELAY,
ROUND(CAST(SUM(CANCELLED) AS FLOAT) / COUNT(*) * 100, 2) AS CANCEL_RATE
FROM flight_data 
WHERE ORIGIN NOT IN ('JFK', 'LGA', 'EWR');

--STEP 5: THE ROOT CAUSE OF BATTLE
--GOAL: TO SEE IF TECH/LATE AIRCRAFT IS A BIGGER ISSUE THAN WEATHER
SELECT 
ORIGIN,
ROUND(AVG(WEATHER_DELAY), 2) AS NATURE_FAULT,
ROUND(AVG(LATE_AIRCRAFT_DELAY), 2) AS SYSTEM_FAULT,
ROUND(AVG(LATE_AIRCRAFT_DELAY)/NULLIF(AVG(WEATHER_DELAY), 0) , 2) AS TECH_TO_WEATHER_RATIO
FROM flight_data 
WHERE ORIGIN IN ('JFK', 'LGA', 'EWR')
GROUP BY ORIGIN;

--STEP 6: THE WEEKLYN RECOVERY AUDIT
--GOAL: FIND IF THERE'S A DAY WHEN THE "SYSTEM FAULT" ACTUALLY DROPS
SELECT 
DAY_OF_WEEK,
COUNT(*) AS TOTAL_FLIGHTS,
ROUND(AVG(LATE_AIRCRAFT_DELAY), 2) AS AVG_SYSTEM_FAULT,
SUM(CANCELLED) AS TOTAL_CANCELS
FROM FLIGHT_DATA 
WHERE ORIGIN IN ('EWR', 'LGA')
GROUP BY day_of_week 
ORDER BY AVG_SYSTEM_FAULT ASC;


--STEP 7: THE LOAD TEST
--GOAL: DOES "BUSIER" MEAN MORE PROBLEMS
SELECT 
DAY_OF_MONTH, -- CHECKING FOR VOLUME PER DAY
COUNT(*) AS DAILY_FLIGHT_COUNT,
ROUND(AVG(LATE_AIRCRAFT_DELAY), 2) AS AVG_SYSTEM_FAULT
FROM FLIGHT_DATA 
WHERE ORIGIN IN ('JFK', 'LGA', 'EWR')
GROUP BY DAY_OF_MONTH
ORDER BY DAILY_FLIGHT_COUNT DESC
LIMIT 10;
